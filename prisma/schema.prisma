generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Source {
  id        Int       @id @default(autoincrement())
  name      String
  url       String    @unique
  category  String?
  createdAt DateTime  @default(now())
  articles  Article[]
}

model Article {
  id          Int       @id @default(autoincrement())
  guid        String    @unique
  title       String
  link        String
  description String?
  thumbnail   String?
  publishedAt DateTime?
  readTimeMin Int?
  isRead      Boolean   @default(false)
  summary         String?
  topics          Json?
  importanceScore Int?
  enrichedAt      DateTime?
  createdAt   DateTime  @default(now())
  sourceId    Int
  source      Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([publishedAt])
  @@index([isRead])
  @@index([enrichedAt])
}

model RateLimit {
  id          Int      @id @default(autoincrement())
  key         String
  count       Int      @default(0)
  windowStart DateTime @default(now())
  @@index([key])
}
