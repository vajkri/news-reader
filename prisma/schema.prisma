generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Source {
  id                  Int       @id @default(autoincrement())
  name                String
  url                 String    @unique
  category            String?
  sourceType          String    @default("rss")
  sitemapPathPattern  String?
  scrapeUrl           String?
  scrapeLinkSelector  String?
  createdAt           DateTime  @default(now())
  articles            Article[]
  feedback            ArticleFeedback[]
}

model Article {
  id          Int       @id @default(autoincrement())
  guid        String    @unique
  title       String
  link        String
  description String?
  thumbnail   String?
  publishedAt DateTime?
  readTimeMin Int?
  isRead      Boolean   @default(false)
  summary         String?
  topics          Json?
  importanceScore Int?
  enrichedAt      DateTime?
  contentType     String?
  thinContent     Boolean?
  createdAt   DateTime  @default(now())
  sourceId    Int
  source      Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  feedback    ArticleFeedback[]

  @@index([sourceId])
  @@index([publishedAt])
  @@index([isRead])
  @@index([enrichedAt])
}

model RateLimit {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  count       Int      @default(0)
  windowStart DateTime @default(now())
}

model UserPreference {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model ArticleFeedback {
  id          Int      @id @default(autoincrement())
  articleId   Int
  direction   String
  reasons     Json
  sourceId    Int
  topics      Json
  contentType String?
  createdAt   DateTime @default(now())

  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  source      Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([direction])
  @@index([articleId])
}
